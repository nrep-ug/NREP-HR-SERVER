# ============================================================
# NREP HR Server — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ─── Server ──────────────────────────────────────────────────
PORT=3005

# ─── CORS ────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins (beyond the
# hard-coded defaults already in corsOptions.js).
# Add the server's own public host here so browser clients
# on that domain are allowed through CORS.
#
# Example (production deployment on alx.derrickml.com):
CORS_EXTRA_ORIGINS=https://alx.derrickml.com,http://alx.derrickml.com

# Comma-separated wildcard base-domain suffixes.
# Any origin whose host ends with one of these is allowed.
# Defaults to: .nrep.ug,.vercel.app
# CORS_BASE_DOMAINS=.nrep.ug,.vercel.app

# ─── Organisation Domain & Email ─────────────────────────────
# Used in the REC calendar invite UID and organiser fields.
NREP_DOMAIN=nrep.ug
NREP_INFO_EMAIL=info@nrep.ug

# ─── Procurement Portal URL ──────────────────────────────────
# Base URL of the procurement / supplier-facing web app.
# Referenced inside outgoing email notifications sent to suppliers.
PROCUREMENT_PORTAL_URL=https://supplies.nrep.ug

# ─── Appwrite ────────────────────────────────────────────────
APPWRITE_ENDPOINT=
APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=

# Appwrite — HR Database
HR_DB_ID=
STAFF_TABLE_ID=
OTP_REQUEST_TABLE_ID=

# Appwrite — Project Database
PROJECT_DB_ID=
PROJECT_TABLE_ID=
PROJECT_TEAM_TABLE_ID=
PROJECT_TASK_TABLE_ID=
PROJECT_TASK_TEAM_TABLE_ID=

# Appwrite — Procurement Database
PROCUREMENT_DB_ID=
PROCUREMENT_POSTS_TABLE_ID=
PROCUREMENT_SUPPLIER_APPLICATION_TABLE_ID=
PROCUREMENT_SUPPLIER_TABLE_ID=
PROCUREMENT_STAFF_TABLE_ID=
PROCUREMENT_CATEGORY_TABLE_ID=
POSTED_PROCUREMENT_BUCKET_ID=

# ─── MySQL ───────────────────────────────────────────────────
MYSQL_HOST=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# ─── Email (Postmark) ────────────────────────────────────────
POSTMARK_API_TOKEN=

# ─── Protected Endpoints ─────────────────────────────────────
# Bearer token required to access GET /metrics
METRICS_SECRET=

# Bearer key required to access POST /api/test/send-test-email
ADMIN_KEY=

# ─── Logging (Pino-Loki) ─────────────────────────────────────
LOKI_HOST=
LOKI_USER=
LOKI_PASSWORD=
